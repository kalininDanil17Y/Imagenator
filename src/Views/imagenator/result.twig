<html>
<head>
    <link href="//maxcdn.bootstrapcdn.com/bootstrap/3.3.0/css/bootstrap.min.css" rel="stylesheet" id="bootstrap-css">
    <script src="//maxcdn.bootstrapcdn.com/bootstrap/3.3.0/js/bootstrap.min.js"></script>
    <script
            src="https://code.jquery.com/jquery-3.6.0.js"
            integrity="sha256-H+K7U5CnXl1h5ywQfKtSj8PCmoN9aaq30gDh27Xc0jk="
            crossorigin="anonymous"></script>
</head>
<body>
<style>

    .gallery-title
    {
        font-size: 36px;
        color: #42B32F;
        text-align: center;
        font-weight: 500;
        margin-bottom: 70px;
    }
    .gallery-title:after {
        content: "";
        position: absolute;
        width: 7.5%;
        left: 46.5%;
        height: 45px;
        border-bottom: 1px solid #5e5e5e;
    }
    .gallery-link
    {
        font-size: 18px;
        color: #42B32F;
        text-align: center;
        text-decoration: none;
    }
    .gallery-link:hover{
        color: #3cbd26;
    }
    .linkblock{
        margin-bottom: 20px;
        text-align: center;
    }
    .btn-default:active .filter-button:active
    {
        background-color: #42B32F;
        color: white;
    }

    .button, .input
    {
        border: 1px solid #42B32F;
        border-radius: 0 5px 5px 0;
        text-align: center;
        color: #42B32F;
        margin-bottom: 30px;

    }
    .button:hover,
    .input:hover
    {
        border: 1px solid #42B32F;
        border-radius: 0 7px 7px 0;
        text-align: center;
        color: #ffffff;
        background-color: #42B32F;

    }
    .input {
        border-radius: 5px 0 0 5px;
    }
    .input:hover {
        border-radius: 7px 0 0 7px;
    }

</style>
<div class="container">
    <div class="row">
        <div class="gallery col-lg-12 col-md-12 col-sm-12 col-xs-12 col-centered">
            <h1 class="gallery-title">Imagenator</h1>
        </div>

        <div class="linkblock">
            <a class="gallery-link" href="/">Назад</a>
        </div>

        <div class="col-lg-3 col-md-3 col-sm-3 col-xs-6">
            <p>Картинка успешно загружена, id: {{ id }}</p>
        </div>
        <div class="col-lg-9 col-md-9 col-sm-9 col-xs-6">
            <p>Ссылка на изобажение</p>
            <input class="input button" style="width: 80%; float:left;" type="text" value="http://localhost/images/{{ id }}.{{ format }}" id="imageLink" disabled>
            <button onclick="copy(this)" style="width: 20%;" class="button">Скопировать</button>
        </div>

    </div>
</div>
<script>
    function copy(but) {
        $('#imageLink').prop('disabled', false);
        var copyText = document.getElementById("imageLink");
        copyText.select();
        document.execCommand("copy");
        $('#imageLink').prop('disabled', true);
        $(but).text("~Скопировано~");
    }
</script>
</body>
</html>
